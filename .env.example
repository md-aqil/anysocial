NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

DATABASE_URL=postgresql://user:password@localhost:5432/oauth_service?schema=public
REDIS_URL=redis://localhost:6379

TOKEN_ENCRYPTION_KEY=<generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
SESSION_SECRET=<random 64-char string>

BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
DEFAULT_TIMEZONE=America/New_York

# Instagram (Meta)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Facebook (Meta)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X/Twitter
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# YouTube (Google)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# AWS S3 / Cloudflare R2 Storage
S3_ENDPOINT=https://s3.amazonaws.com  # or R2 URL
S3_BUCKET=social-media-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
